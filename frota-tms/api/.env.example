DATABASE_URL="file:./dev.db"
# Produção / Docker Compose (PostgreSQL):
# DATABASE_URL="postgresql://frota:SENHA@localhost:5432/frota_tms"

# Obrigatório em produção: ≥24 caracteres, único
JWT_SECRET="change-me-in-production-min-24-chars"
JWT_EXPIRES_IN="8h"
PORT=4000

# Dev: URL do Vite. Produção (API serve o front): use o domínio público ou *
CORS_ORIGIN="http://localhost:5173"
NODE_ENV=development

# Só no primeiro bootstrap: SEED_ON_START=true FORCE_SEED=true
# SEED_ON_START=false
