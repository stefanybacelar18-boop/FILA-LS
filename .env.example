# Copie para .env.local e preencha os valores

# Supabase (Dashboard > Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# URL pública do app
# Produção (Vercel): https://fila-lsl.vercel.app  (ajuste com sua URL real)
# LAN (notebook):     http://192.168.0.122:3000
NEXT_PUBLIC_APP_URL=https://fila-lsl.vercel.app

# Google Maps (opcional — geofence funciona com lat/lng manual)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# === APENAS TESTES LAN — desligar na operação real ===
# NEXT_PUBLIC_SKIP_GEOFENCE=true
# NEXT_PUBLIC_SKIP_CHECKIN_LIMITS=true
