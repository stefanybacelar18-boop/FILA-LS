# Copie para .env.local e preencha os valores

# Supabase (Dashboard > Settings > API)
# Use a Project URL — NÃO use a REST URL (/rest/v1)
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# URL pública do app (FilaDock)
# Produção (Vercel): https://fila-lsl.vercel.app  (ajuste com sua URL real de deploy)
# LAN (notebook):     http://192.168.0.122:3000
NEXT_PUBLIC_APP_URL=https://fila-lsl.vercel.app

# Google Maps (opcional — geofence funciona com lat/lng manual)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# === APENAS DESENVOLVIMENTO LOCAL — ignorados automaticamente em produção ===
# SKIP_GEOFENCE=true
# SKIP_CHECKIN_LIMITS=true
# Legado (evite em produção): NEXT_PUBLIC_SKIP_GEOFENCE / NEXT_PUBLIC_SKIP_CHECKIN_LIMITS
