# Copie para .env.local e preencha os valores

# Supabase (Dashboard > Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# URL pública — IP do notebook na Wi-Fi da empresa (NUNCA 0.0.0.0)
# Exemplo: http://192.168.0.122:3000
NEXT_PUBLIC_APP_URL=http://192.168.0.122:3000

# Google Maps (opcional — geofence funciona com lat/lng manual)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# === APENAS TESTES LAN — desligar na operação real ===
# NEXT_PUBLIC_SKIP_GEOFENCE=true
# NEXT_PUBLIC_SKIP_CHECKIN_LIMITS=true
